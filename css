n{border:none;border-radius:999px;padding:4px 10px;font-size:11px;text-transform:uppercase;letter-spacing:.12em;cursor:pointer;background:linear-gradient(135deg,rgba(53,230,168,.18),rgba(53,230,255,.12));color:var(--text);box-shadow:0 0 0 1px rgba(255,255,255,.06);transition:background .12s ease,transform .12s ease,box-shadow .12s ease}.world-select-btn:hover:not(:disabled){transform:translateY(-1px);box-shadow:0 0 0 1px rgba(255,255,255,.12),0 0 18px rgba(53,230,168,.5);background:linear-gradient(135deg,rgba(53,230,168,.26),rgba(53,230,255,.2))}.world-select-btn:disabled{opacity:.4;cursor:default;transform:none;box-shadow:0 0 0 1px rgba(255,255,255,.04);background:linear-gradient(135deg,rgba(255,255,255,.04),rgba(0,0,0,.4))}@media(max-width:800px){.main-grid{grid-template-columns:minmax(0,1fr)}}
